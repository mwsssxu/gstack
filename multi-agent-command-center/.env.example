# 多 Agent 协作指挥中心 - 环境变量模板

# 服务器配置
HOST=0.0.0.0
PORT=8001
DEBUG=true

# 数据库配置
SQLITE_DATABASE_URL=sqlite:///./command_center.db
POSTGRESQL_DATABASE_URL=postgresql://postgres:0okm9ijn@localhost:5432/command_center
MONGODB_DATABASE_URL=mongodb://localhost:27017/command_center

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=re2019
REDIS_DB=0

# LLM API 配置 - 阿里云百炼 (主要)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# LLM API 配置 - OpenAI/ModelScope (备用)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api-inference.modelscope.cn/v1/
OPENAI_MODEL=Qwen/Qwen3.5-397B-A17B

# LLM 提供商选择: dashscope, openai
LLM_PROVIDER=dashscope

# 存储路径
ARTIFACTS_DIR=~/.command-center/artifacts
SCREENSHOTS_DIR=~/.command-center/screenshots

# 浏览器配置
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# CORS 配置
CORS_ORIGINS=["http://localhost:3001","http://127.0.0.1:3001"]